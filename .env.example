# =============================================================
# daily-automation 환경변수 설정
# 이 파일을 복사해서 .env 로 저장한 뒤 실제 값을 채워넣으세요.
# cp .env.example .env
# =============================================================

# ── Telegram ──────────────────────────────────────────────────
# 발급: Telegram에서 @BotFather 에게 /newbot 명령
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 발급: @userinfobot 에게 메시지 보내면 Chat ID 알려줌
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── OpenWeatherMap ────────────────────────────────────────────
# 발급: https://openweathermap.org/api → 무료 계정 생성 후 API Keys 탭
OPENWEATHER_API_KEY=your_openweather_api_key_here

# 날씨 조회 도시 (기본값: Seoul)
WEATHER_CITY=Seoul

# ── Todoist ───────────────────────────────────────────────────
# 발급: https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=your_todoist_api_token_here

# ── Google Calendar (OAuth2) ──────────────────────────────────
# 발급: https://console.cloud.google.com/
#   1. 프로젝트 생성 → API 및 서비스 → Google Calendar API 활성화
#   2. 사용자 인증 정보 → OAuth 2.0 클라이언트 ID 생성 (데스크톱 앱)
#   3. client_id / client_secret 복사
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# refresh_token은 로컬에서 python auth_google.py 실행 후 발급됩니다.
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# 조회할 캘린더 ID (보통 Gmail 주소. 구글 캘린더 설정 → 캘린더 통합에서 확인)
GOOGLE_CALENDAR_ID=your_email@gmail.com

# ── Idea Bot (Telegram → Obsidian) ───────────────────────────
# 발급: @BotFather → /newbot (아침 브리핑 봇과 별개 봇)
IDEA_BOT_TOKEN=your_idea_bot_token_here

# 허용할 Chat ID (본인 ID. 비워두면 모든 채팅 허용)
IDEA_BOT_CHAT_ID=your_telegram_chat_id_here
